{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://krateo.io/snowplow/bench/ledger_row.schema.json",
  "title": "Snowplow bench canonical ledger row",
  "description": "Frozen schema covering docs/bench-restructure-path-b-plan-2026-06-02.md \u00a7F.1 key list. Bumping requires a fresh PM gate.",
  "type": "object",
  "required": [
    "tag",
    "ship_date",
    "scale",
    "uptime_at_capture_s",
    "cells",
    "mix_weighted",
    "convergence_mass_s6_p99",
    "convergence_mass_s7_p99",
    "convergence_mass_s8_p99",
    "convergence_per_mutation_p99_mix",
    "convergence_per_class_hot_p99",
